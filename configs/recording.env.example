# CAN 포트
# leader: 사람이 손으로 움직이는 마스터 팔
# follower: 실제로 펜을 잡는 슬레이브 팔
# piper-setup으로 이름을 바꾼 경우 can_leader1/can_follower1을 쓰고,
# 이름 변경 전이면 can0/can1처럼 실제 인터페이스명 입력
LEADER_PORT=can_leader1
FOLLOWER_PORT=can_follower1

# LeRobot metadata에 기록될 robot ID
# 같은 실험 장비에서는 ID 고정 권장
ROBOT_ID=piper_follower1
TELEOP_ID=piper_leader1

# camera_check.py로 확인한 카메라 index
# TOP_CAM: 화이트보드 전체, 펜 시작 위치, 팔 움직임을 보는 상방 카메라
# WRIST_CAM: 펜촉과 보드 접촉을 가까이 보는 팔목 카메라
# index 값: lerobot_robot_piper/camera_check.py 실행 결과의 video 번호
TOP_CAM=0
WRIST_CAM=1
CAM_WIDTH=640
CAM_HEIGHT=480
FPS=30

# 데이터셋
# DATASET_REPO_ID: owner/dataset_name 형식
# TASK: 공백 포함 값이므로 반드시 따옴표 사용
HF_USER=your_hf_name
DATASET_REPO_ID=your_hf_name/piper_write_light
NUM_EPISODES=5
EPISODE_TIME_S=60
TASK="write AIIII"
PUSH_TO_HUB=false
DISPLAY_DATA=true

# 안전 설정
# follower 한 timestep action 변화량 제한
# 두 팔 초기 자세가 완전히 맞지 않으면 5보다 더 낮게 시작
MAX_RELATIVE_TARGET=5
